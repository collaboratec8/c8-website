  /* FAQ */
  .faq{padding:128px 0;background:var(--canvas)}
  .faq-list{max-width:820px;display:flex;flex-direction:column;gap:8px}
  .faq-item{background:var(--surface);border-radius:var(--radius);border:1px solid transparent;transition:border-color .2s}
  .faq-item[open]{border-color:var(--indigo);background:#fff}
  .faq-item summary{list-style:none;cursor:pointer;padding:20px 24px;display:flex;justify-content:space-between;align-items:center;gap:16px}
  .faq-item summary::-webkit-details-marker{display:none}
  .faq-item summary h3{font-family:var(--font-display);font-weight:600;font-size:17px;letter-spacing:-0.01em;line-height:1.3;color:var(--ink);margin:0}
  .faq-item .toggle{font-family:var(--font-mono);font-size:22px;color:var(--indigo);flex-shrink:0;transition:transform .2s}
  .faq-item[open] .toggle{transform:rotate(45deg)}
  .faq-item p{padding:0 24px 24px;color:var(--ink-70);font-size:15.5px;line-height:1.65}

  /* SOCIAL STRIP */
  .social-strip{padding:80px 0;background:var(--surface)}
  .ss-wrap{display:grid;grid-template-columns:1.4fr 1fr;gap:60px;align-items:center}
  .ss-left h2{font-family:var(--font-display);font-weight:700;font-size:clamp(26px,2.8vw,36px);letter-spacing:-0.025em;line-height:1.1;margin-top:14px;margin-bottom:12px}
  .ss-left h2 span{color:var(--indigo)}
  .ss-left p{color:var(--ink-50);font-size:16px;max-width:460px;line-height:1.55}
  .ss-right{display:flex;flex-direction:column;align-items:flex-end}
  .socials{display:flex;gap:12px}
  .s-icon{width:52px;height:52px;border-radius:50%;background:#fff;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--ink);text-decoration:none;transition:transform .2s,background .2s,color .2s,border-color .2s}
  .s-icon:hover{background:var(--ink);color:#fff;border-color:var(--ink);transform:translateY(-2px)}

  /* CONTACT */
  .contact{padding:128px 0;background:var(--canvas)}
  .contact-wrap{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start}
  .contact h2{font-family:var(--font-display);font-weight:700;font-size:clamp(34px,4vw,52px);line-height:1.02;letter-spacing:-0.03em;margin-bottom:18px;margin-top:14px}
  .contact h2 span{color:var(--indigo)}
  .contact-intro{color:var(--ink-50);font-size:17px;line-height:1.6;max-width:440px;margin-bottom:32px}
  .contact-meta{display:flex;flex-direction:column;gap:16px;margin-bottom:32px}
  .contact-meta .row{display:flex;gap:14px;align-items:center}
  .contact-meta .label{font-family:var(--font-mono);font-size:11px;color:var(--ink-30);text-transform:uppercase;letter-spacing:0.1em;width:70px}
  .contact-meta .val{font-size:15.5px;color:var(--ink)}
  .contact-meta .val a{color:inherit;text-decoration:none}
  .contact-meta .val a:hover{color:var(--indigo)}
  .contact-form{background:var(--surface);border-radius:var(--radius-lg);padding:36px}
  .contact-form h3{font-family:var(--font-display);font-weight:600;font-size:22px;margin-bottom:22px}
  .contact-form .btn{width:100%;justify-content:center;margin-top:8px}
  .form-field{display:flex;flex-direction:column;gap:6px;margin-bottom:16px}
  .form-field label{font-family:var(--font-mono);font-size:11px;text-transform:uppercase;color:var(--ink-50);letter-spacing:0.08em}
  .form-field input,.form-field textarea{padding:12px 14px;border:1px solid var(--border);border-radius:var(--radius);background:#fff;font-family:var(--font-body);font-size:15px;resize:vertical}
  .form-field input:focus,.form-field textarea:focus{outline:none;border-color:var(--indigo)}
  .cal-embed-wrap{background:#fff;border:1px solid var(--border);border-radius:var(--radius-lg);padding:12px;min-height:640px;position:sticky;top:100px}
  #cal-inline-embed{min-height:620px}

  @media (max-width:1000px){
    .problems{grid-template-columns:1fr}
    .tiers{grid-template-columns:1fr}
    .sol-grid{grid-template-columns:1fr}
    .case-grid{grid-template-columns:1fr}
    .steps{grid-template-columns:repeat(2,1fr);gap:40px 0}
    .steps::before{display:none}
    .about-grid,.magnet .wrap,.contact-wrap,.ss-wrap{grid-template-columns:1fr;gap:40px}
    .ss-right{align-items:flex-start}
    .magnet .wrap{padding:48px 32px}
    .hero-metrics{grid-template-columns:repeat(2,1fr);gap:24px}
    .hero-metrics .m::after{display:none!important}
    .about-stats{padding:36px;grid-template-columns:1fr 1fr;gap:24px}
    .about-stats .big{font-size:32px}
    .cal-embed-wrap{position:static}
  }
  @media (max-width:600px){
    .hero{padding:56px 0 72px}
    .problem,.services,.solutions,.about,.cases,.process,.magnet,.faq,.contact{padding:72px 0}
    .social-strip{padding:56px 0}
    .p-card{flex-direction:column;gap:12px;padding:24px}
    .tier{padding:28px 24px}
    .sol{padding:32px 24px}
    .magnet .wrap{padding:36px 24px;border-radius:18px}
    .section-head{margin-bottom:36px}
    .section-head p{font-size:16px}
    .hero-metrics{grid-template-columns:1fr 1fr;gap:20px;padding-top:24px}
    .hero-metrics .num{font-size:24px}
    .hero-metrics .lbl{font-size:12px}
    .about-stats{padding:28px;gap:20px}
    .about-stats .big{font-size:26px}
    .about-stats .txt{font-size:12.5px}
    .hero h1{font-size:40px;line-height:1}
    .hero .sub{font-size:16px}
    .hero-outcomes{gap:8px}
    .hero-outcomes .tag{font-size:12.5px;padding:8px 12px}
    .hero-ctas{flex-direction:column}
    .hero-ctas .btn{justify-content:center;width:100%}
    .creds-row{gap:20px;flex-direction:column;align-items:flex-start}
    .creds-row .co{font-size:18px}
    .steps{grid-template-columns:1fr;gap:32px}
    .tier .tname{font-size:24px}
    .sol h3{font-size:22px}
    .contact-meta .row{flex-direction:column;align-items:flex-start;gap:4px}
    .contact-meta .label{width:auto}
  }
</style>
</BaseLayout>
